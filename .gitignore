# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ---- IDE & editors ----
.idea/
.vscode/
*.swp
*.swo

# ---- Dependencies ----
node_modules/
venv/
.venv/
/.pnp
.pnp.js
.yarn/install-state.gz

# ---- Python ----
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
.eggs/
*.egg

# ---- Environment & secrets ----
.env
.env.*
*.env
credentials.json
*token.json*
*.pem
*.key
.credentials

# ---- Build outputs ----
/build
dist/
/.next/
/out/
next-env.d.ts
*.tsbuildinfo

# ---- Testing & coverage ----
/coverage
htmlcov/
.pytest_cache/
.coverage
test_reports/

# ---- Logs ----
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# ---- System files ----
.DS_Store
Thumbs.db
dump.rdb

# ---- Archives & large binaries ----
*.zip
*.tar.gz
*.tar
*.tgz
*.pack
*.deb
*.dylib

# ---- Caches ----
.cache/
.ipynb_checkpoints/

# ---- Agent/tool metadata (not project code) ----
.claude/
.emergent/
.gitconfig
.chainlit
chainlit.md

# ---- Misc temp files ----
memory/test_credentials.md
